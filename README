```swift
import Foundation

struct Developer {
    let name: String = "Rodrigo Soares"
    let role: String = "Mobile Software Engineer"
    
    let skills: [Skill] = [
        .language("Swift"),
        .language("SwiftUI"),
        .language("UIKit"),
        .framework("Combine"),
        .framework("Core Data"),
        .architecture("MVVM"),
        .architecture("Clean Architecture"),
        .tool("Xcode"),
        .tool("Git"),
        .pattern("Design Patterns")
    ]
    
    let passion: String = """
        Transformar ideias em experiências mobile incríveis 📱
        Escrever código limpo e escalável 🎯
        Sempre aprendendo algo novo 🚀
    """
    
    func code() {
        while true {
            learn()
            build()
            ship()
        }
    }
}

enum Skill {
    case language(String)
    case framework(String)
    case architecture(String)
    case tool(String)
    case pattern(String)
}
```

